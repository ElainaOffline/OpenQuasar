      },
      "render_controllers": [
                {
            "controller.render.player.first_person":"variable.is_first_person"
        },
        {
            "controller.render.player.third_person":"!variable.is_first_person && !variable.map_face_icon"
        },
        {
            "controller.render.player.first_person_bloom":"variable.is_first_person"
        },
        {
            "controller.render.player.third_person_bloom":"!variable.is_first_person && !variable.map_face_icon"
        },


        
        {
          "controller.render.zb_0": "query.has_armor_slot(0) && query.is_in_ui && q.is_on_screen && q.is_alive"
        },
        {
          "controller.render.zb_1": "query.has_armor_slot(1) && query.is_in_ui && q.is_on_screen && q.is_alive"
        },
        {
          "controller.render.zb_2": "query.has_armor_slot(2) && query.is_in_ui && q.is_on_screen && q.is_alive"
        },
        {
          "controller.render.zb_3": "query.has_armor_slot(3) && query.is_in_ui && q.is_on_screen && q.is_alive"
        },
        {
          "controller.render.keystrokes_space": "query.is_in_ui && query.is_on_screen"
        },
        {
          "controller.render.keystrokes_lmb": "query.is_in_ui && query.is_on_screen"
        },
        {
          "controller.render.keystrokes_rmb": "query.is_in_ui && query.is_on_screen"
        },
        {
          "controller.render.keystrokes_w": "query.is_in_ui && query.is_on_screen"
        },
        {
          "controller.render.keystrokes_a": "query.is_in_ui && query.is_on_screen"
        },
        {
          "controller.render.keystrokes_s": "query.is_in_ui && query.is_on_screen"
        },
        {
          "controller.render.keystrokes_d": "query.is_in_ui && query.is_on_screen"
        },
        {
          "controller.render.keystrokes_p": "query.is_in_ui && query.is_on_screen"
        }
      ],
      "enable_attachables": true
