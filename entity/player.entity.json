      "scripts": {
        "scale": "0.9375",
        "initialize": [
          "variable.is_holding_right = 0.0;",
          "variable.is_blinking = 0.0;",
          "variable.last_blink_time = 0.0;",
          "variable.hand_bob = 0.0;",


          "variable.t_pr_rotation = 0.0;",
          "variable.t_pr_w = 0.0;",
          "variable.t_pr_a = 0.0;",
          "variable.t_pr_s = 0.0;",
          "variable.t_pr_d = 0.0;",
          "variable.jump_blend = 0.0;",
          "variable.lmb_blend = 0.0;",
          "variable.rmb_blend = 0.0;",
          "variable.w_blend = 0.0;",
          "variable.a_blend = 0.0;",
          "variable.s_blend = 0.0;",
          "variable.d_blend = 0.0;",
          "variable.rmb_block_all = 0.0;",
          "variable.lmb_blend_mix = 0.0;",
          "variable.rmb_blend_mix_block = 0.0;",
          //开关
          "variable.win = 1.0;", // 0.0表示启用win版 1.0表示启用手机版(主要体现在动画以及过渡时长)
          "variable.wasd = 0.0;", //WASD AD按键滞留，0.0表示取消滞留，1.0表示开启滞留，默认0.0
          "variable.rmb_block = 1.0;", //rmb 特殊方块放置启用rmb，0.0表示关闭，1.0表示开启，默认0.0
          "variable.jump = 1.0;", //跳跃 按键连击动画，0.0表示连击时持续保持特定大小，1.0表示连击时随跳跃频率改变大小，默认1.0
          "variable.lmb = 1.0;", //lmb 按键连击动画，0.0表示连击时持续保持特定大小，1.0表示连击时随攻击频率改变大小，默认1.0
          "variable.lmb_mix_blend = 1.0;", //lmb 连击渐变，0.0表示连击时无渐变改变，1.0表示连击时渐变随攻击频率改变，默认1.0
          "variable.rmb_mix_blend_block = 1.0;", //rmb 连击渐变，0.0表示连击时无渐变改变，1.0表示连击时渐变随攻击频率改变，默认1.0
          //参数
          "variable.blend_time_enter = variable.win ? 2.7 : 1.0;", //所有按键入场过度时长倍率 win版为1.0 手机版为2.7(跳跃有单独修改的部分)
          "variable.blend_time_appear = variable.win ? 2.7 : 1.0;", //所有按键出场过度时长倍率 win版为1.0 手机版为2.7(跳跃有单独修改的部分)
          "variable.dynamic_size_enter = variable.win ? 0.83 : 1.0;", //所有按键入场动画大小倍率 win版为1.0 手机版为0.85
          "variable.dynamic_size_appear = variable.win ? 1.0 : 1.0;", //所有按键出场动画大小倍率 win版为1.0 手机版为1.0
          "variable.dynamic_time_enter = variable.win ? 1.0 : 1.0;", //所有按键入场动画时间倍率 win版为1.0 手机版为1.0
          "variable.jump_blend_time_enter = variable.win ? v.blend_time_enter * 0.05 : v.blend_time_enter * 0.03;", //跳跃 渐变入场时间，默认为0.03s，数值越大，入场越快 (大于1无意义)
          "variable.jump_blend_time_appear = variable.win ? v.blend_time_appear * 0.005 : v.blend_time_appear * 0.01;", //跳跃 渐变出场时间，默认为0.01s，数值越大，出场越快 (大于1无意义)
          "variable.lmb_blend_time_enter = v.blend_time_enter * 0.03;", //lmb 渐变入场时间，默认为0.03s，数值越大，入场越快 (大于1无意义)
          "variable.lmb_blend_time_appear = v.blend_time_appear * 0.01;", //lmb 渐变出场时间，默认为0.01s，数值越大，出场越快 (大于1无意义)
          "variable.lmb_mix_blend_time_enter = v.blend_time_enter * 0.025;", //lmb 渐变随攻击频率改变 渐变入场时间，默认为0.01s，数值越大，入场越快 (大于1无意义)
          "variable.lmb_mix_blend_time_appear = v.blend_time_appear * 0.015;", //lmb 渐变随攻击频率改变 渐变出场时间，默认为0.01s，数值越大，出场越快 (大于1无意义)
          "variable.rmb_blend_time_enter = v.blend_time_enter * 0.01;", //rmb 渐变入场时间，默认为0.01s，数值越大，入场越快 (大于1无意义)
          "variable.rmb_blend_time_appear = v.blend_time_appear * 0.01;", //rmb 渐变出场时间，默认为0.01s，数值越大，出场越快 (大于1无意义)
          "variable.wasd_blend_time_enter = v.blend_time_enter * 0.02;", //WASD 渐变入场时间，默认为0.02s，数值越大，入场越快 (大于1无意义)
          "variable.wasd_blend_time_appear = v.blend_time_appear * 0.01;", //WASD 渐变出场时间，默认为0.01s，数值越大，出场越快 (大于1无意义)
          "variable.t_pr_jump_dynamic_size_enter = v.dynamic_size_enter * 0.93;", //跳跃 按键动态效果入场大小，默认为0.93，数值越大，入场按键尺寸越大 (建议小于等于1)
          "variable.t_pr_jump_dynamic_size_appear = v.dynamic_size_appear * 1.06;", //跳跃 按键动态效果出场大小，默认为1.06，数值越大，出场按键尺寸越大 (建议大于等于1)
          "variable.t_pr_lmb_dynamic_size_enter = v.dynamic_size_enter * 0.93;", //lmb 按键动态效果入场大小，默认为0.93，数值越大，入场按键尺寸越大 (建议小于等于1)
          "variable.t_pr_lmb_dynamic_size_appear = v.dynamic_size_appear * 1.06;", //lmb 按键动态效果出场大小，默认为1.06，数值越大，出场按键尺寸越大 (建议大于等于1)
          "variable.t_pr_rmb_dynamic_size_enter = v.dynamic_size_enter * 0.93;", //rmb 按键动态效果入场大小，默认为0.93，数值越大，入场按键尺寸越大 (建议小于等于1)
          "variable.t_pr_rmb_dynamic_size_appear = v.dynamic_size_appear * 1.06;", //rmb 按键动态效果出场大小，默认为1.06，数值越大，出场按键尺寸越大 (建议大于等于1)
          "variable.t_pr_w_dynamic_size_enter = v.dynamic_size_enter * 0.93;", //W 按键动态效果入场大小，默认为0.93，数值越大，入场按键尺寸越大 (建议小于等于1)
          "variable.t_pr_w_dynamic_size_appear = v.dynamic_size_appear * 1.06;", //W 按键动态效果出场大小，默认为1.06，数值越大，出场按键尺寸越大 (建议大于等于1)
          "variable.t_pr_w_dynamic_time_enter = v.dynamic_time_enter * 0.75;", //W 按键动态效果入场时间，默认为0.75，数值越大，入场时间越快 (建议小于等于1) (入场时间随按键入场尺寸不同而表现出不同效果，一般很小可忽略)
          "variable.t_pr_a_dynamic_size_enter = v.dynamic_size_enter * 0.93;", //A 按键动态效果入场大小，默认为0.93，数值越大，入场按键尺寸越大 (建议小于等于1)
          "variable.t_pr_a_dynamic_size_appear = v.dynamic_size_appear * 1.06;", //A 按键动态效果出场大小，默认为1.06，数值越大，出场按键尺寸越大 (建议大于等于1)
          "variable.t_pr_a_dynamic_time_enter = v.dynamic_time_enter * 0.75;", //A 按键动态效果入场时间，默认为0.75，数值越大，入场时间越快 (建议小于等于1) (入场时间随按键入场尺寸不同而表现出不同效果，一般很小可忽略)
          "variable.t_pr_s_dynamic_size_enter = v.dynamic_size_enter * 0.93;", //S 按键动态效果入场大小，默认为0.93，数值越大，入场按键尺寸越大 (建议小于等于1)
          "variable.t_pr_s_dynamic_size_appear = v.dynamic_size_appear * 1.06;", //S 按键动态效果出场大小，默认为1.06，数值越大，出场按键尺寸越大 (建议大于等于1)
          "variable.t_pr_s_dynamic_time_enter = v.dynamic_time_enter * 0.75;", //S 按键动态效果入场时间，默认为0.75，数值越大，入场时间越快 (建议小于等于1) (入场时间随按键入场尺寸不同而表现出不同效果，一般很小可忽略)
          "variable.t_pr_d_dynamic_size_enter = v.dynamic_size_enter * 0.93;", //D 按键动态效果入场大小，默认为0.93，数值越大，入场按键尺寸越大 (建议小于等于1)
          "variable.t_pr_d_dynamic_size_appear = v.dynamic_size_appear * 1.06;", //D 按键动态效果出场大小，默认为1.06，数值越大，出场按键尺寸越大 (建议大于等于1)
          "variable.t_pr_d_dynamic_time_enter = v.dynamic_time_enter * 0.75;" //D 按键动态效果入场时间，默认为0.75，数值越大，入场时间越快 (建议小于等于1) (入场时间随按键入场尺寸不同而表现出不同效果，一般很小可忽略)"
        ],
        "pre_animation": [
          "v.is_enchanted_helmet = q.armor_material_slot(0) == 1 || q.armor_material_slot(0) == 3; v.is_enchanted_chestplate = q.armor_material_slot(1) == 1 || q.armor_material_slot(1) == 3; v.is_enchanted_leggings = q.armor_material_slot(2) == 1 || q.armor_material_slot(2) == 3; v.is_enchanted_boots = q.armor_material_slot(3) == 1 || q.armor_material_slot(3) == 3;",

          
          "variable.helmet_layer_visible = 1.0;",
          "variable.leg_layer_visible = 1.0;",
          "variable.boot_layer_visible = 1.0;",
          "variable.chest_layer_visible = 1.0;",
          "variable.attack_body_rot_y = Math.sin(360*Math.sqrt(variable.attack_time)) * 5.0;",
          "variable.tcos0 = (math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / variable.gliding_speed_value) * 57.3;",
          "variable.first_person_rotation_factor = math.sin((1 - variable.attack_time) * 180.0);",
          "variable.hand_bob = query.life_time < 0.01 ? 0.0 : variable.hand_bob + ((query.is_on_ground && query.is_alive ? math.clamp(math.sqrt(math.pow(query.position_delta(0), 2.0) + math.pow(query.position_delta(2), 2.0)), 0.0, 0.1) : 0.0) - variable.hand_bob) * 0.02;",
          "variable.map_angle = math.clamp(1 - variable.player_x_rotation / 45.1, 0.0, 1.0);",
          "variable.item_use_normalized = query.main_hand_item_use_duration / query.main_hand_item_max_duration;"
        ],
        "animate": [
          "root",

          "c_t_pr_variable",
          "c_t_pr_root"
        ]
      },
